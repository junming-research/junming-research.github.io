---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Honors"
  description="Academic honors and awards of Junming Wen."
>
  <div class="px-6 py-12">
    <div class="mx-auto" style="max-width: var(--content-width);">

      <p class="mb-3 text-xs font-semibold uppercase tracking-widest text-accent">Recognition</p>
      <h1 class="mb-8 font-serif text-4xl font-bold tracking-tight text-slate-900" style="letter-spacing: -0.02em;">
        Academic Honors &amp; Awards
      </h1>

      <div class="divide-y divide-slate-100">

        <div class="flex items-baseline gap-5 py-2.5">
          <span class="w-12 flex-shrink-0 font-mono text-xs text-slate-400">2023</span>
          <div class="min-w-0 flex-1">
            <p class="text-sm font-medium text-slate-900">Best Research Paper Award (Graded A+)</p>
            <p class="text-xs text-slate-400">National University of Singapore &amp; Bolloré Logistics</p>
          </div>
        </div>

        <div class="flex items-baseline gap-5 py-2.5">
          <span class="w-12 flex-shrink-0 font-mono text-xs text-slate-400">2022</span>
          <div class="min-w-0 flex-1">
            <p class="text-sm font-medium text-slate-900">First Class Honours</p>
            <p class="text-xs text-slate-400">Macau University of Science and Technology</p>
          </div>
        </div>

        <div class="flex items-baseline gap-5 py-2.5">
          <span class="w-12 flex-shrink-0 font-mono text-xs text-slate-400">2022</span>
          <div class="min-w-0 flex-1">
            <p class="text-sm font-medium text-slate-900">University Commencement Student Representative</p>
            <p class="text-xs text-slate-400">Faculty Representative — Macau University of Science and Technology</p>
          </div>
        </div>

        <div class="flex items-baseline gap-5 py-2.5">
          <span class="w-12 flex-shrink-0 font-mono text-xs text-slate-400">2022</span>
          <div class="min-w-0 flex-1">
            <p class="text-sm font-medium text-slate-900">Outstanding Academic and Cultural Award</p>
            <p class="text-xs text-slate-400">Macau University of Science and Technology</p>
          </div>
        </div>

        <div class="flex items-baseline gap-5 py-2.5">
          <span class="w-12 flex-shrink-0 font-mono text-xs text-slate-400">2022</span>
          <div class="min-w-0 flex-1">
            <p class="text-sm font-medium text-slate-900">Dean's Honour List</p>
            <p class="text-xs text-slate-400">Macau University of Science and Technology</p>
          </div>
        </div>

        <div class="flex items-baseline gap-5 py-2.5">
          <span class="w-12 flex-shrink-0 font-mono text-xs text-slate-400">2021</span>
          <div class="min-w-0 flex-1">
            <p class="text-sm font-medium text-slate-900">Outstanding Academic and Cultural Award</p>
            <p class="text-xs text-slate-400">Macau University of Science and Technology</p>
          </div>
        </div>

        <div class="flex items-baseline gap-5 py-2.5">
          <span class="w-12 flex-shrink-0 font-mono text-xs text-slate-400">2021</span>
          <div class="min-w-0 flex-1">
            <p class="text-sm font-medium text-slate-900">Dean's Honour List</p>
            <p class="text-xs text-slate-400">Macau University of Science and Technology</p>
          </div>
        </div>

        <div class="flex items-baseline gap-5 py-2.5">
          <span class="w-12 flex-shrink-0 font-mono text-xs text-slate-400">2020</span>
          <div class="min-w-0 flex-1">
            <p class="text-sm font-medium text-slate-900">Outstanding Academic and Cultural Award</p>
            <p class="text-xs text-slate-400">Macau University of Science and Technology</p>
          </div>
        </div>

        <div class="flex items-baseline gap-5 py-2.5">
          <span class="w-12 flex-shrink-0 font-mono text-xs text-slate-400">2020</span>
          <div class="min-w-0 flex-1">
            <p class="text-sm font-medium text-slate-900">Dean's Honour List</p>
            <p class="text-xs text-slate-400">Macau University of Science and Technology</p>
          </div>
        </div>

        <div class="flex items-baseline gap-5 py-2.5">
          <span class="w-12 flex-shrink-0 font-mono text-xs text-slate-400">2019</span>
          <div class="min-w-0 flex-1">
            <p class="text-sm font-medium text-slate-900">Dean's Honour List</p>
            <p class="text-xs text-slate-400">Macau University of Science and Technology</p>
          </div>
        </div>

      </div>

    </div>
  </div>
</BaseLayout>

---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Experience"
  description="Professional and campus experience of Junming Wen."
>
  <div class="px-6 py-12">
    <div class="mx-auto" style="max-width: var(--content-width);">

      <p class="mb-3 text-xs font-semibold uppercase tracking-widest text-accent">Experience</p>
      <h1 class="mb-8 font-serif text-4xl font-bold tracking-tight text-slate-900" style="letter-spacing: -0.02em;">
        Experience
      </h1>

      <!-- ── Professional Experience ────────────────────── -->
      <section class="mb-10">
        <h2 class="mb-5 text-lg font-semibold text-slate-900">Professional Experience</h2>
        <div class="space-y-0">

          <!-- BASF Senior SCO -->
          <div class="flex gap-5">
            <div class="flex flex-col items-center">
              <div class="mt-1.5 h-2.5 w-2.5 flex-shrink-0 rounded-full bg-accent"></div>
              <div class="mt-2 w-px flex-1 bg-slate-200"></div>
            </div>
            <div class="pb-6">
              <p class="mb-0.5 text-sm font-medium text-slate-400">Mar 2024 – Sep 2025</p>
              <h3 class="mb-1 text-base font-semibold text-slate-900">Senior Supply Chain Officer</h3>
              <p class="mb-2 text-sm text-slate-500">
                BASF &nbsp;·&nbsp; Petrochemical Division &nbsp;·&nbsp; Mainland China
              </p>
              <p class="text-sm leading-relaxed text-slate-500">
                Served as Commercial Supply Chain Data Scientist and Business Analyst, supporting the start-up of Asia's largest integrated petrochemical site (ZVS Project), with primary focus on Cracker cluster and EOEGMG cluster products. Led development of a Supply Chain Intelligence Matrix and implemented 8 dashboard monitors spanning the full supply chain, leveraging over 3 million rows of integrated data from SAP ERP, OMP Planning System, and Enterprise Data Lake.
              </p>
            </div>
          </div>

          <!-- BASF Intern -->
          <div class="flex gap-5">
            <div class="flex flex-col items-center">
              <div class="mt-1.5 h-2.5 w-2.5 flex-shrink-0 rounded-full bg-accent"></div>
              <div class="mt-2 w-px flex-1 bg-slate-200"></div>
            </div>
            <div class="pb-2">
              <p class="mb-0.5 text-sm font-medium text-slate-400">May 2023 – Jan 2024</p>
              <h3 class="mb-1 text-base font-semibold text-slate-900">Global Logistics Procurement Intern</h3>
              <p class="mb-2 text-sm text-slate-500">
                BASF &nbsp;·&nbsp; Global Procurement Division &nbsp;·&nbsp; Singapore
              </p>
              <p class="text-sm leading-relaxed text-slate-500">
                Managed LCL spot RFQ processes for global BASF entities, completing 100+ tasks with logistics service providers. Supported the 23/24 global airfreight tender by cleaning and consolidating 30,000+ rows of historical shipment data. Developed an automated LCL spot rate comparison tool in MS Excel.
              </p>
            </div>
          </div>

        </div>
      </section>

      <hr class="border-slate-200" />

      <!-- ── Campus Experience ───────────────────────────── -->
      <section class="mt-10">
        <h2 class="mb-5 text-lg font-semibold text-slate-900">Campus Experience</h2>
        <div class="space-y-0">

          <!-- PATA -->
          <div class="flex gap-5">
            <div class="flex flex-col items-center">
              <div class="mt-1.5 h-2.5 w-2.5 flex-shrink-0 rounded-full bg-slate-400"></div>
              <div class="mt-2 w-px flex-1 bg-slate-200"></div>
            </div>
            <div class="pb-2">
              <p class="mb-0.5 text-sm font-medium text-slate-400">Jun 2021 – Oct 2022</p>
              <h3 class="mb-1 text-base font-semibold text-slate-900">President</h3>
              <p class="mb-2 text-sm text-slate-500">
                Pacific Asia Travel Association (PATA) Macau Student Chapter &nbsp;·&nbsp; Macau
              </p>
              <p class="text-sm leading-relaxed text-slate-500">
                Led a team of 9 board members and 50+ executive committee members from 5 local universities, overseeing event planning and member management. Established partnerships with government bodies and industry, including the Macau Government, Sands China Ltd., and Galaxy Entertainment Group.
              </p>
            </div>
          </div>

        </div>
      </section>

    </div>
  </div>
</BaseLayout>

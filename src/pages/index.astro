---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Home"
  description="Personal academic website of Junming Wen, PhD researcher at the University of Glasgow."
>
  <div class="px-6 py-12">
    <div class="mx-auto" style="max-width: var(--content-width);">

      <!-- ── Profile block ──────────────────────────────────── -->
      <div class="mb-10">

        <!-- Name + position + pitch -->
        <div>
          <h1
            class="mb-1 font-serif text-3xl font-bold text-slate-900 sm:text-4xl"
            style="letter-spacing: -0.02em;"
          >
            Junming Wen
          </h1>
          <p class="mb-4 text-base text-slate-500">
            PhD Candidate
          </p>
          <p class="mb-6 max-w-md text-sm leading-relaxed text-slate-500">
            Working at the intersection of
            <span class="font-medium text-slate-700">Supply Chain Management &amp; Big Data Analytics</span>
            and
            <span class="font-medium text-slate-700">Artificial Intelligence</span>.
          </p>

          <!-- CTA Buttons -->
          <div class="flex flex-wrap gap-2.5">

            <!-- GitHub -->
            <a
              href="https://github.com/junming-sg"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1.5 rounded-lg bg-slate-900 px-4 py-2 text-sm font-medium text-white transition-colors duration-200 hover:bg-slate-700"
            >
              <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z" />
              </svg>
              GitHub
            </a>

            <!-- LinkedIn -->
            <a
              href="https://www.linkedin.com/in/junmingwennus/"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1.5 rounded-lg bg-[#0077B5] px-4 py-2 text-sm font-medium text-white transition-colors duration-200 hover:bg-[#005e8e]"
            >
              <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
              </svg>
              LinkedIn
            </a>

            <!-- Email -->
            <a
              href="mailto:junming.wen@u.nus.edu"
              class="inline-flex items-center gap-1.5 rounded-lg border border-slate-200 px-4 py-2 text-sm font-medium text-slate-600 transition-colors duration-200 hover:border-slate-300 hover:text-slate-900"
            >
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect width="20" height="16" x="2" y="4" rx="2" />
                <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
              </svg>
              Email
            </a>

          </div>
        </div>
      </div>

      <hr class="border-slate-200" />

      <!-- ── Research Interests ─────────────────────────────── -->
      <section class="my-8">
        <p class="mb-4 text-xs font-semibold uppercase tracking-widest text-accent">Research Interests</p>
        <ul class="grid grid-cols-2 gap-x-4 gap-y-2">
          <li class="flex items-start gap-2.5 text-sm text-slate-600">
            <span class="mt-1.5 h-1.5 w-1.5 flex-shrink-0 rounded-full bg-accent"></span>
            Supply Chain Management
          </li>
          <li class="flex items-start gap-2.5 text-sm text-slate-600">
            <span class="mt-1.5 h-1.5 w-1.5 flex-shrink-0 rounded-full bg-accent"></span>
            Operations Management
          </li>
          <li class="flex items-start gap-2.5 text-sm text-slate-600">
            <span class="mt-1.5 h-1.5 w-1.5 flex-shrink-0 rounded-full bg-accent"></span>
            Green &amp; Sustainability
          </li>
          <li class="flex items-start gap-2.5 text-sm text-slate-600">
            <span class="mt-1.5 h-1.5 w-1.5 flex-shrink-0 rounded-full bg-accent"></span>
            Big Data Analytics
          </li>
          <li class="flex items-start gap-2.5 text-sm text-slate-600">
            <span class="mt-1.5 h-1.5 w-1.5 flex-shrink-0 rounded-full bg-accent"></span>
            Artificial Intelligence
          </li>
          <li class="flex items-start gap-2.5 text-sm text-slate-600">
            <span class="mt-1.5 h-1.5 w-1.5 flex-shrink-0 rounded-full bg-accent"></span>
            Machine Learning
          </li>
        </ul>
      </section>

      <hr class="border-slate-200" />

      <!-- ── Education ──────────────────────────────────────── -->
      <section class="my-8">
        <p class="mb-4 text-xs font-semibold uppercase tracking-widest text-accent">Education</p>
        <div class="space-y-4">

          <!-- PhD -->
          <div class="flex gap-4">
            <div class="mt-1.5 h-2 w-2 flex-shrink-0 rounded-full bg-accent"></div>
            <div>
              <p class="font-medium text-slate-900">Doctor of Philosophy (PhD) — Management</p>
              <p class="text-sm text-slate-500">
                University of Glasgow &nbsp;·&nbsp; Glasgow, UK &nbsp;·&nbsp; 2025 – Present
              </p>
              <p class="mt-0.5 text-sm text-slate-500">
                Supervisors: Prof. Ming Lim &amp; Dr. Javier Yanez-Arenas
              </p>
            </div>
          </div>

          <!-- Master -->
          <div class="flex gap-4">
            <div class="mt-1.5 h-2 w-2 flex-shrink-0 rounded-full bg-slate-300"></div>
            <div>
              <p class="font-medium text-slate-900">Master of Science (MSc) — Supply Chain Management</p>
              <p class="text-sm text-slate-500">
                National University of Singapore &nbsp;·&nbsp; Singapore &nbsp;·&nbsp; 2022 – 2024
              </p>
            </div>
          </div>

          <!-- Bachelor -->
          <div class="flex gap-4">
            <div class="mt-1.5 h-2 w-2 flex-shrink-0 rounded-full bg-slate-300"></div>
            <div>
              <p class="font-medium text-slate-900">Bachelor's Degree</p>
              <p class="text-sm text-slate-500">
                Macau University of Science and Technology &nbsp;·&nbsp; Macau &nbsp;·&nbsp; 2018 – 2022
              </p>
            </div>
          </div>

        </div>
      </section>

      <hr class="border-slate-200" />

      <!-- ── Visitor Map ──────────────────────────────────── -->
      <section class="my-8">
        <p class="mb-4 text-xs font-semibold uppercase tracking-widest text-accent">Visitor Map</p>
        <div class="flex justify-center opacity-60">
          <div id="visitor-map-wrapper" class="overflow-x-auto"></div>
        </div>
      </section>

      <script is:inline>
        (function () {
          function initVisitorMap() {
            const wrapper = document.getElementById('visitor-map-wrapper');
            if (!wrapper) return;
            wrapper.innerHTML = '';
            const s = document.createElement('script');
            s.id = 'mapmyvisitors';
            s.type = 'text/javascript';
            s.src = 'https://mapmyvisitors.com/map.js?cl=1a3365&w=500&t=tt&d=meqOP1STjLaQKUGzJwa65lAEu7OUysBlkE7KLDl3kwQ&co=ffffff&cmo=ffbb00&cmn=ff4343&ct=1a3365';
            wrapper.appendChild(s);
            wrapper.addEventListener('click', function (e) { e.preventDefault(); e.stopPropagation(); }, true);
            wrapper.addEventListener('contextmenu', function (e) { e.preventDefault(); }, true);
          }

          initVisitorMap();

          if (!window.__mmvListenerAdded) {
            document.addEventListener('astro:page-load', initVisitorMap);
            window.__mmvListenerAdded = true;
          }
        })();
      </script>

    </div>
  </div>
</BaseLayout>

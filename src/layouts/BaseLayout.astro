---
import { ClientRouter } from 'astro:transitions';
import NavBar from '../components/layout/NavBar.astro';
import Footer from '../components/layout/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = '[PLACEHOLDER — TO BE REPLACED] Personal academic website.',
} = Astro.props;

const fadeOut  = { name: 'page-fade-out', duration: '80ms',  easing: 'ease-in',                       fillMode: 'both' };
const slideIn  = { name: 'page-slide-in', duration: '300ms', easing: 'cubic-bezier(0.16, 1, 0.3, 1)', fillMode: 'both' };
const pageTransition = {
  forwards:  { old: fadeOut, new: slideIn },
  backwards: { old: fadeOut, new: slideIn },
};

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const pageTitle = title === 'Home'
  ? 'Junming Wen'
  : `${title} | Junming Wen`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalURL} />
    <meta name="description" content={description} />
    <!-- Open Graph -->
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content="website" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <ClientRouter />
  </head>
  <body class="bg-white text-slate-900">
    <NavBar transition:persist />
    <main class="flex-1" style="padding-top: var(--nav-height);" transition:animate={pageTransition}>
      <slot />
    </main>
    <Footer />
  </body>
</html>

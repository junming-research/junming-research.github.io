---
const navLinks = [
  { href: '/',             label: 'About'        },
  { href: '/research',     label: 'Research'     },
  { href: '/experience',   label: 'Experience'   },
  { href: '/honors',       label: 'Honors'       },
  // Publications hidden until content is available
  // Teaching hidden until content is ready
];

const currentPath = Astro.url.pathname;

function isActive(href: string): boolean {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---

<header class="fixed top-0 left-0 right-0 z-50 h-16 bg-white/90 backdrop-blur-sm border-b border-slate-200">
  <nav
    class="mx-auto flex h-full items-center justify-between px-6"
    style="max-width: var(--layout-width);"
    aria-label="Main navigation"
  >
    <!-- Name — plain text, not a link -->
    <span class="text-sm font-medium text-slate-400 select-none">
      Junming Wen
    </span>

    <!-- Desktop nav links -->
    <ul class="hidden md:flex items-center gap-7" role="list" id="nav-links">
      {navLinks.map(({ href, label }) => (
        <li>
          <a
            href={href}
            data-navhref={href}
            class={`text-sm font-medium transition-colors duration-200 ${
              isActive(href)
                ? 'text-accent'
                : 'text-slate-500 hover:text-slate-900'
            }`}
            aria-current={isActive(href) ? 'page' : undefined}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Mobile hamburger (CSS-only, no JS) -->
    <details class="md:hidden relative group">
      <summary
        class="list-none cursor-pointer p-2 text-slate-500 hover:text-slate-900 transition-colors"
        aria-label="Open navigation menu"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <line x1="3" y1="6"  x2="21" y2="6"  />
          <line x1="3" y1="12" x2="21" y2="12" />
          <line x1="3" y1="18" x2="21" y2="18" />
        </svg>
      </summary>

      <ul
        class="absolute right-0 top-full mt-2 w-48 rounded-xl border border-slate-200 bg-white shadow-lg py-1.5"
        role="list"
        id="nav-links-mobile"
      >
        {navLinks.map(({ href, label }) => (
          <li>
            <a
              href={href}
              data-navhref={href}
              class={`block px-4 py-2 text-sm transition-colors duration-200 ${
                isActive(href)
                  ? 'text-accent font-medium'
                  : 'text-slate-500 hover:text-slate-900 hover:bg-slate-50'
              }`}
            >
              {label}
            </a>
          </li>
        ))}
      </ul>
    </details>
  </nav>
</header>

<script>
  function updateActiveNav() {
    const path = window.location.pathname;
    document.querySelectorAll<HTMLAnchorElement>('[data-navhref]').forEach((a) => {
      const href = a.dataset.navhref!;
      const active = href === '/' ? path === '/' : path.startsWith(href);
      if (active) {
        a.classList.add('text-accent');
        a.classList.remove('text-slate-500', 'hover:text-slate-900', 'hover:bg-slate-50');
        a.setAttribute('aria-current', 'page');
      } else {
        a.classList.remove('text-accent');
        a.classList.add('text-slate-500', 'hover:text-slate-900');
        a.removeAttribute('aria-current');
      }
    });
  }

  // Run on initial load and after every view transition
  updateActiveNav();
  document.addEventListener('astro:page-load', updateActiveNav);
</script>

---
const navLinks = [
  { href: '/',             label: 'About'        },
  { href: '/research',     label: 'Research'     },
  { href: '/experience',   label: 'Experience'   },
  { href: '/honors',       label: 'Honors'       },
  // Publications hidden until content is available
  // Teaching hidden until content is ready
];

const currentPath = Astro.url.pathname;

function isActive(href: string): boolean {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---

<header class="fixed top-0 left-0 right-0 z-50 h-16 bg-white/90 backdrop-blur-sm border-b border-slate-200">
  <nav
    class="mx-auto flex h-full items-center justify-between px-6"
    style="max-width: var(--layout-width);"
    aria-label="Main navigation"
  >
    <!-- Name — plain text, not a link -->
    <span class="text-sm font-medium text-slate-400 select-none">
      Junming Wen
    </span>

    <!-- Desktop nav links -->
    <ul class="hidden md:flex items-center gap-7" role="list" id="nav-links">
      {navLinks.map(({ href, label }) => (
        <li>
          <a
            href={href}
            data-navhref={href}
            class={`text-sm font-medium transition-colors duration-200 ${
              isActive(href)
                ? 'text-accent'
                : 'text-slate-500 hover:text-slate-900'
            }`}
            aria-current={isActive(href) ? 'page' : undefined}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Mobile hamburger -->
    <div class="md:hidden relative">
      <button
        id="mobile-menu-btn"
        class="p-2 text-slate-500 hover:text-slate-900 transition-colors duration-200"
        aria-label="Toggle navigation menu"
        aria-expanded="false"
        aria-controls="mobile-menu-panel"
      >
        <span class="relative block w-5 h-5">
          <svg id="icon-hamburger" class="absolute inset-0 transition-opacity duration-200" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
            <line x1="3" y1="6"  x2="21" y2="6"  />
            <line x1="3" y1="12" x2="21" y2="12" />
            <line x1="3" y1="18" x2="21" y2="18" />
          </svg>
          <svg id="icon-close" class="absolute inset-0 opacity-0 transition-opacity duration-200" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
            <line x1="18" y1="6"  x2="6"  y2="18" />
            <line x1="6"  y1="6"  x2="18" y2="18" />
          </svg>
        </span>
      </button>

      <!--
        CSS grid trick: grid-template-rows 0fr→1fr animates height without
        needing scrollHeight. Inner div needs overflow:hidden + min-height:0.
      -->
      <div
        id="mobile-menu-panel"
        class="absolute right-0 top-full mt-2 w-48"
        style="display:grid; grid-template-rows:0fr; pointer-events:none; transition:grid-template-rows 300ms cubic-bezier(0.16,1,0.3,1);"
      >
        <div style="overflow:hidden; min-height:0;">
          <ul
            class="rounded-xl border border-slate-200 bg-white shadow-lg py-1.5"
            role="list"
            id="nav-links-mobile"
          >
            {navLinks.map(({ href, label }) => (
              <li>
                <a
                  href={href}
                  data-navhref={href}
                  class={`block px-4 py-2 text-sm transition-colors duration-200 ${
                    isActive(href)
                      ? 'text-accent font-medium'
                      : 'text-slate-500 hover:text-slate-900 hover:bg-slate-50'
                  }`}
                >
                  {label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </nav>
</header>

<script>
  // ── Active nav highlight ──────────────────────────────────────────────────
  function updateActiveNav() {
    const path = window.location.pathname;
    document.querySelectorAll<HTMLAnchorElement>('[data-navhref]').forEach((a) => {
      const href = a.dataset.navhref!;
      const active = href === '/' ? path === '/' : path.startsWith(href);
      if (active) {
        a.classList.add('text-accent');
        a.classList.remove('text-slate-500', 'hover:text-slate-900', 'hover:bg-slate-50');
        a.setAttribute('aria-current', 'page');
      } else {
        a.classList.remove('text-accent');
        a.classList.add('text-slate-500', 'hover:text-slate-900');
        a.removeAttribute('aria-current');
      }
    });
  }

  updateActiveNav();
  document.addEventListener('astro:page-load', updateActiveNav);

  // ── Mobile menu ───────────────────────────────────────────────────────────
  function setupMobileMenu() {
    const btn        = document.getElementById('mobile-menu-btn')   as HTMLElement | null;
    const panel      = document.getElementById('mobile-menu-panel') as HTMLElement | null;
    const iconBurger = document.getElementById('icon-hamburger')    as HTMLElement | null;
    const iconClose  = document.getElementById('icon-close')        as HTMLElement | null;

    // Guard: skip if already initialised (btn persists via transition:persist)
    if (!btn || !panel || btn.dataset.menuReady) return;
    btn.dataset.menuReady = '1';

    const isOpen = () => btn.getAttribute('aria-expanded') === 'true';

    function openMenu() {
      btn.setAttribute('aria-expanded', 'true');
      panel.style.gridTemplateRows = '1fr';
      panel.style.pointerEvents    = 'auto';
      if (iconBurger) iconBurger.style.opacity = '0';
      if (iconClose)  iconClose.style.opacity  = '1';
    }

    function closeMenu() {
      btn.setAttribute('aria-expanded', 'false');
      panel.style.gridTemplateRows = '0fr';
      panel.style.pointerEvents    = 'none';
      if (iconBurger) iconBurger.style.opacity = '1';
      if (iconClose)  iconClose.style.opacity  = '0';
    }

    // stopPropagation isolates the button click from the outside-click handler
    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      isOpen() ? closeMenu() : openMenu();
    });

    // Outside-click: only fires when click didn't originate from the button
    document.addEventListener('click', (e) => {
      if (isOpen() && !panel.contains(e.target as Node)) {
        closeMenu();
      }
    });
  }

  document.addEventListener('astro:page-load', setupMobileMenu);
</script>

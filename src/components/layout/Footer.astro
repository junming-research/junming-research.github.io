---
const currentYear = new Date().getFullYear();
const lastUpdated = 'May 2026';
---

<footer class="border-t border-slate-200">
  <div
    class="mx-auto flex flex-col items-center justify-between gap-3 px-6 py-10 sm:flex-row"
    style="max-width: var(--layout-width);"
  >
    <p class="text-sm text-slate-400">
      © {currentYear} Junming Wen. All rights reserved.
    </p>
    <p class="text-sm text-slate-400">
      Last updated: {lastUpdated}
    </p>
  </div>
</footer>
